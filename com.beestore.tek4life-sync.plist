<dict>
    <key>Label</key>
    <string>com.beestore.tek4life-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/klark/Projetos /Bee Store/Bee-Supplier/tek4life_sync.py</string>
    </array>
    <key>StartCalendarInterval</key>
    <array>
        <!-- 8h03 -->
        <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>8</integer><key>Minute</key><integer>3</integer></dict>
